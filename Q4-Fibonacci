def fib(n):
    if n <= 2:
        return 1
    return fib(n - 1) + fib(n - 2)

# We will print the first 10 Fibonacci numbers
n_terms = 10
    
print(f"The first {n_terms} Fibonacci numbers are:")
print("-" * 35)
    
for i in range(1, n_terms + 1):
    result = fib(i)
    # Using end=', ' to print them in a single line like the sequence in the image
    if i < n_terms:
        print(result, end=', ')
    else:
        print(result, end='...')
            
print("\n\nSpecific checks:")
print(f"The 5th Fibonacci number is: {fib(5)}")
print(f"The 8th Fibonacci number is: {fib(8)}")